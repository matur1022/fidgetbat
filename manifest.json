{
  "manifest_version": 3,
  "name": "FidgetBat",
  "version": "1.0.0",
  "description": "A physics bat-and-ball fidget toy overlaid on YouTube videos. Grab the bat, swing it, rack up hits, unlock skins.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle FidgetBat"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
